# Google OAuth Client ID (opcional - se nao definido, qualquer um pode usar)
# Para criar: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Tipo: Web application | Authorized JS origins: http://localhost:8000
GOOGLE_CLIENT_ID=

# Caminho para o arquivo de cookies do Google (gerado pelo salvar_login.py do scraper)
COOKIES_FILE=../google-reviews-scraper/google_cookies.json

# Pasta onde os relatórios serão salvos
OUTPUT_DIR=./output
